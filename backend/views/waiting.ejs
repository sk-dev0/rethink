<% layout('layout/boilerplates') %>

<div class="container mt-5" style="max-width: 600px;">
    <div class="text-center mb-4">
        <h1 class="fw-bold">待機中</h1>
        <p class="text-muted">他の参加者の対話が完了するまでお待ちください</p>
    </div>

    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-body p-4">
            <h5 class="card-title text-primary"><i class="bi bi-people me-2"></i>完了状況</h5>
            <p class="card-text text-muted small">対話が完了した人数です</p>
            <h2 class="text-center fw-bold">
                <span id="count">0/0</span>
                <span class="fs-5 text-muted"> 人完了</span>
            </h2>
        </div>
    </div>

    <% if (isHost) { %>
    <div class="card shadow-sm mb-4">
        <div class="card-body p-4 text-center">
            <h5 class="card-title"><i class="bi bi-play-circle me-2 text-success"></i>ホスト操作</h5>
            <p class="card-text text-muted small">全員完了すると議論を開始できます</p>
            <button class="btn btn-success btn-lg mt-2" id="startBtn" disabled>
                議論を開始する
            </button>
        </div>
    </div>
    <% } else { %>
    <div class="card shadow-sm mb-4">
        <div class="card-body p-4 text-center">
            <h5 class="card-title"><i class="bi bi-hourglass-split me-2 text-warning"></i>開始待ち</h5>
            <p class="card-text text-muted small">全員完了後、ホストが議論を開始します</p>
            <div class="spinner-border text-primary mt-2" role="status">
                <span class="visually-hidden">Loading...</span>
            </div>
        </div>
    </div>
    <% } %>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const roomId = '<%= roomId %>';

    const startBtn = document.getElementById('startBtn');
    if (startBtn) {
        startBtn.addEventListener('click', () => {
            socket.emit('startDiscussion', roomId);
        });
    };

    socket.emit('joinWaiting', roomId);

    // 参加人数の更新を検知して、全員が揃うとボタンを押せるようにする
    socket.on('updateWaitingCount', (count, total) => {
        document.getElementById('count').textContent = count + '/' + total;
        if (count >= total && total > 0) {
            const startBtn = document.getElementById('startBtn');
            if (startBtn) startBtn.disabled = false;
        }
    });

    // 議論フェーズへ遷移する
    socket.on('redirectToDiscussion', (url) => {
        window.location.href = url;
    });
</script>