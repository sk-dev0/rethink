<% layout('layout/boilerplates') %>

<h1>ロビー</h1>
<p>ルームID: <%= roomId %></p>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const roomId = '<%= roomId %>';

    socket.emit('joinRoom', roomId);

    socket.on('updateCount', (count) => {
        console.log('現在の参加人数:', count);
    });

    socket.on('redirect', (url) => {
        window.location.href = url;
    });
</script>