<% layout('layout/boilerplates') %>
<% block('style').append('<link href="/css/debate.css" rel="stylesheet">') %>

<!-- ヘッダー -->
<header class="bg-dark text-white py-4 mb-4 shadow">
  <div class="container">
    <h1 class="mb-0 fw-bold">
      <span class="text-info">Rethink</span> - AI Debate
    </h1>
    <p class="mb-0 text-secondary small">複数のアイデアをAIが4フェーズで議論し、深く考察します</p>
  </div>
</header>

<div class="pb-5">

  <!-- 入力フォームカード -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">

      <!-- 議題入力 -->
      <div class="mb-4">
        <label for="topic" class="form-label fw-semibold">議題・前提条件</label>
        <textarea
          id="topic"
          class="form-control"
          rows="3"
          placeholder="例: 新しいプロダクトのUI設計において、どちらのアプローチが優れているか"
        ></textarea>
      </div>

      <!-- エージェントカード群 -->
      <div id="agentsContainer" class="row mb-3">
        <!-- アイデアA（初期・削除不可） -->
        <div class="col-md-6 mb-4 agent-col" data-index="0">
          <div class="border rounded p-3 agent-card" data-agent-index="0">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-primary mb-0">アイデアA</h6>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">主張（core_claim）</label>
              <textarea class="form-control border-primary agent-claim" rows="2" placeholder="例: シンプルで直感的なデザインを優先する"></textarea>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">根拠（rationale）</label>
              <textarea class="form-control border-primary agent-rationale" rows="2" placeholder="例: ユーザー調査でシンプルなUIの満足度が高く、離脱率が低い実績がある"></textarea>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">前提条件（preconditions）</label>
              <textarea class="form-control border-primary agent-preconditions" rows="2" placeholder="例: ターゲットユーザーは技術に詳しくない一般層である"></textarea>
            </div>
            <div class="mb-0">
              <label class="form-label small fw-semibold">立場を支える具体的な事実・経験（任意）</label>
              <textarea class="form-control border-primary agent-experience" rows="2" placeholder="例: 実際に使ったユーザーからシンプルなUIの方が迷わないという声を聞いた"></textarea>
            </div>
          </div>
        </div>

        <!-- アイデアB（初期・削除不可） -->
        <div class="col-md-6 mb-4 agent-col" data-index="1">
          <div class="border rounded p-3 agent-card" data-agent-index="1">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-danger mb-0">アイデアB</h6>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">主張（core_claim）</label>
              <textarea class="form-control border-danger agent-claim" rows="2" placeholder="例: 機能を豊富に揃えたパワーユーザー向けデザインを優先する"></textarea>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">根拠（rationale）</label>
              <textarea class="form-control border-danger agent-rationale" rows="2" placeholder="例: 上位20%のヘビーユーザーが売上の80%を占め、彼らは機能の多さを評価している"></textarea>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">前提条件（preconditions）</label>
              <textarea class="form-control border-danger agent-preconditions" rows="2" placeholder="例: ユーザーの多様なニーズに応えるためには機能の幅が必要である"></textarea>
            </div>
            <div class="mb-0">
              <label class="form-label small fw-semibold">立場を支える具体的な事実・経験（任意）</label>
              <textarea class="form-control border-danger agent-experience" rows="2" placeholder="例: ヘビーユーザーが機能の多さを理由に継続利用しているという事例を観察した"></textarea>
            </div>
          </div>
        </div>
      </div>

      <!-- アイデア追加ボタン -->
      <div class="mb-4">
        <button id="addAgentBtn" type="button" class="btn btn-outline-secondary">
          + アイデアを追加
        </button>
        <span class="text-muted small ms-2">（3つ以上のアイデアで多角的な議論が可能です）</span>
      </div>

      <!-- フェーズ3ターン数設定 -->
      <div class="mb-4">
        <label for="maxTurns" class="form-label fw-semibold">フェーズ3の議論ターン数（サブ議題あたり）</label>
        <div class="d-flex align-items-center gap-3">
          <input
            type="number"
            id="maxTurns"
            class="form-control"
            style="width: 100px;"
            value="2"
            min="1"
            max="2"
          >
          <span class="text-muted small">ターン（1〜2、デフォルト2で攻撃モードα→βを1サイクル）</span>
        </div>
      </div>

      <!-- 議論開始ボタン -->
      <div class="d-grid d-md-flex">
        <button id="startBtn" class="btn btn-dark btn-lg px-5">
          議論開始
        </button>
      </div>

    </div>
  </div>

  <!-- 結果表示エリア（初期非表示） -->
  <div id="resultArea" class="d-none">

    <!-- フェーズ1: 意見表明 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ1: 意見表明</h2>
      <div class="accordion" id="phase1Accordion">
        <div id="phase1Content"></div>
      </div>
    </div>

    <!-- フェーズ2: 情報取得・反論・サブ議題抽出 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ2: 情報取得・反論・サブ議題抽出</h2>
      <div class="accordion" id="phase2Accordion">
        <div id="phase2Content"></div>
      </div>
    </div>

    <!-- フェーズ3: サブ議題別議論 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ3: サブ議題別議論</h2>
      <div class="accordion" id="phase3Accordion">
        <div id="phase3Content"></div>
      </div>
    </div>

    <!-- フェーズ4: 統合表明とまとめ -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ4: 統合表明とまとめ</h2>
      <div id="phase4Content"></div>

      <!-- 最終まとめ -->
      <div class="card border-success shadow-sm mt-4">
        <div class="card-header bg-success text-white fw-semibold">
          最終総括レポート
        </div>
        <div class="card-body">
          <p id="summaryContent" class="mb-0" style="white-space: pre-wrap;"></p>
        </div>
      </div>

    </div>

  </div>

</div>

<% block('script').append('<script src="/js/main.js"></script>') %>