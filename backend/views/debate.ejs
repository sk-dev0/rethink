<% layout('layout/boilerplates') %>
<% block('style').append('<link href="/css/debate.css" rel="stylesheet">') %>

<!--
<!- ヘッダー ->
<header class="bg-dark text-white py-4 mb-4 shadow">
  <div class="container">
    <h1 class="mb-0 fw-bold">
      <span class="text-info">Rethink</span> - AI Debate
    </h1>
    <p class="mb-0 text-secondary small">複数のアイデアをAIが4フェーズで議論し、深く考察します</p>
  </div>
</header>
-->

<!-- プロフィールから自動生成されたエージェント -->
<div id="profilesContainer" class="row mb-3">

    <!-- main.jsが必要とするダミー要素 -->
    <input type="hidden" id="maxTurns" value="2">
    <button id="addAgentBtn" style="display:none;"></button>

    <div class="text-center mb-5">
        <div class="card border-primary">
            <div class="card-header bg-primary text-white fw-bold">
                <i class="bi bi-chat-square-text me-2"></i>議題
            </div>
            <div class="card-body py-3">
                <div class="fw-bold mb-0" id="topicDisplay"></div>
            </div>
        </div>
        <input type="hidden" id="topic" value="<%= typeof topic !== 'undefined' ? topic : '' %>">
    </div>

    <% const colors = ['primary', 'danger', 'success', 'warning', 'info', 'secondary']; %>
    <% profiles.forEach((profile, i) => { %>
    <div class="col-md-6 mb-4 agent-col" data-index="<%= i %>">
        <div class="border border-<%= colors[i] %> rounded p-3 agent-card" data-agent-index="<%= i %>">
            <h6 class="fw-bold text-<%= colors[i] %> mb-3">アイデア<%= ['A','B','C','D','E','F'][i] %></h6>

            <p class="small fw-semibold mb-1">主張（core_claim）</p>
            <div class="border border-<%= colors[i] %> rounded p-2 mb-3" style="min-height: 80px; max-height: 80px; overflow-y: auto;">
                <p class="small mb-0"><%= profile.core_claim %></p>
            </div>

            <p class="small fw-semibold mb-1">根拠（rationale）</p>
            <div class="border border-<%= colors[i] %> rounded p-2 mb-3" style="min-height: 80px; max-height: 80px; overflow-y: auto;">
              <p class="small mb-0"><%= profile.rationale %></p>
            </div>

            <p class="small fw-semibold mb-1">前提条件（preconditions）</p>
            <div class="border border-<%= colors[i] %> rounded p-2 mb-3" style="min-height: 80px; max-height: 80px; overflow-y: auto;">
              <p class="small mb-0"><%= profile.preconditions %></p>
            </div>

            <p class="small fw-semibold mb-1">立場を支える具体的な事実・経験（任意）</p>
            <div class="border border-<%= colors[i] %> rounded p-2 mb-3" style="min-height: 80px; max-height: 80px; overflow-y: auto;">
              <p class="small mb-0"><%= profile.experience %></p>
            </div>

            <input type="hidden" class="agent-claim" value="<%= profile.core_claim %>">
            <input type="hidden" class="agent-rationale" value="<%= profile.rationale %>">
            <input type="hidden" class="agent-preconditions" value="<%= profile.preconditions %>">
            <input type="hidden" class="agent-experience" value="<%= profile.experience %>">
        </div>
    </div>
    <% }) %>
</div>

<div class="my-4">
    <button id="startBtn" class="btn btn-dark btn-lg w-100 rounded-pill">
        <i class="bi bi-play-fill me-2"></i>議論を開始する
    </button>
</div>



  <!-- 結果表示エリア（初期非表示） -->
  <div id="resultArea" class="d-none">

    <!-- フェーズ1: 意見表明 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ1: 意見表明</h2>
      <div class="accordion" id="phase1Accordion">
        <div id="phase1Content"></div>
      </div>
    </div>

    <!-- フェーズ2: 情報取得・反論・サブ議題抽出 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ2: 情報取得・反論・サブ議題抽出</h2>
      <div class="accordion" id="phase2Accordion">
        <div id="phase2Content"></div>
      </div>
    </div>

    <!-- フェーズ3: サブ議題別議論 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ3: サブ議題別議論</h2>
      <div class="accordion" id="phase3Accordion">
        <div id="phase3Content"></div>
      </div>
    </div>

    <!-- 前提検証トラック -->
    <div id="assumptionTrackSection" class="mb-4 d-none">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ4: 前提検証トラック (γ攻撃)</h2>
      <div class="accordion" id="assumptionTrackAccordion">
        <div id="assumptionTrackContent"></div>
      </div>
    </div>
    
    <!-- フェーズ4: 統合表明とまとめ -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ5: 統合表明とまとめ</h2>
      <div id="phase4Content"></div>

      <!-- 最終まとめ -->
      <div class="card border-success shadow-sm mt-4">
        <div class="card-header bg-success text-white fw-semibold">
          最終総括レポート
        </div>
        <div class="card-body">
          <p id="summaryContent" class="mb-0" style="white-space: pre-wrap;"></p>
        </div>
      </div>

      <!-- マインドマップ1: 議論フェーズ -->
      <div class="card border-info shadow-sm mt-4">
        <div class="card-header bg-info text-white fw-semibold d-flex justify-content-between align-items-center">
          <span>マインドマップ①（議論フェーズ）</span>
          <button id="downloadMindmapBtn" class="btn btn-sm btn-light d-none" type="button">
            画像を保存（PNG）
          </button>
        </div>
        <div class="card-body pb-2">
          <div id="mindmapContent" style="width:100%;height:75vh;min-height:400px;overflow:auto;border:1px solid #dee2e6;border-radius:0.375rem;"></div>
          <p class="text-muted small mt-2 mb-0 text-center">
            Ctrl＋スクロール: ズーム ／ スクロールバー: 移動
          </p>
        </div>
      </div>

      <!-- マインドマップ2: 統合フェーズ -->
      <div class="card border-success shadow-sm mt-4">
        <div class="card-header bg-success text-white fw-semibold d-flex justify-content-between align-items-center">
          <span>マインドマップ②（統合フェーズ）</span>
          <button id="downloadMindmap2Btn" class="btn btn-sm btn-light d-none" type="button">
            画像を保存（PNG）
          </button>
        </div>
        <div class="card-body pb-2">
          <div id="mindmapContent2" style="width:100%;height:75vh;min-height:400px;overflow:auto;border:1px solid #dee2e6;border-radius:0.375rem;"></div>
          <p class="text-muted small mt-2 mb-0 text-center">
            Ctrl＋スクロール: ズーム ／ スクロールバー: 移動
          </p>
        </div>
      </div>

    </div>



  </div>

</div>

<% block('script').append('<script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>') %>
<% block('script').append('<script src="/js/main.js"></script>') %>
<script>
  const topicRaw = document.getElementById('topic').value;
  const lines = topicRaw.split('・').filter(l => l.trim());
  const display = document.getElementById('topicDisplay');
  display.innerHTML = lines.map((line, i) => 
      i === 0 
          ? `<p class="mb-1">${line.trim()}</p>`
          : `<p class="mb-0 text-muted small">・${line.trim()}</p>`
  ).join('');
</script>
