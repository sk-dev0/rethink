<% layout('layout/boilerplates') %>
<% block('style').append('<link href="/css/debate.css" rel="stylesheet">') %>
<% block('style').append(`
<style>
  /* 詳細UIの境界線用トークン: 枠線の色と太さを統一する */
  :root {
    --detail-border-color: #111;
    --detail-border-width: 3px;
  }

  /* 詳細UI: 目次画面とフェーズ別ナビゲーションは debate2.ejs のみで管理する */
  .debate-detail-root {
    margin-top: 2rem;
    /* 詳細UIのフォント: 入力カードと同じフォント設定を引き継ぐ */
    font-family: inherit;
  }

  .debate-overview-title {
    font-size: clamp(2rem, 5vw, 4rem);
    font-weight: 300;
    text-align: center;
    margin-bottom: 3rem;
    letter-spacing: 0.04em;
  }

  .debate-overview-track {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    flex-wrap: nowrap;
  }

  .debate-track-link {
    width: 56px;
    height: 24px;
    background: #1f6988;
    border: var(--detail-border-width) solid var(--detail-border-color);
    flex: 0 0 auto;
  }

  .debate-track-arrow {
    width: 0;
    height: 0;
    border-top: 58px solid transparent;
    border-bottom: 58px solid transparent;
    border-left: 72px solid #1f6988;
    filter: drop-shadow(0 0 0 #0f3242);
    flex: 0 0 auto;
  }

  .debate-phase-box {
    width: 205px;
    min-height: 330px;
    padding: 1.5rem 1rem;
    border: var(--detail-border-width) solid var(--detail-border-color);
    background: #fff;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1rem;
    text-align: center;
    cursor: pointer;
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .debate-phase-box:hover {
    transform: translateY(-4px);
    box-shadow: 0 18px 40px rgba(0, 0, 0, 0.08);
    border-color: #1f6988;
  }

  .debate-phase-box.is-active {
    border-color: #1f6988;
    box-shadow: 0 18px 40px rgba(31, 105, 136, 0.18);
  }

  .debate-phase-box-title {
    font-size: clamp(1.8rem, 2.6vw, 2.6rem);
    font-weight: 300;
  }

  .debate-phase-box-lines {
    font-size: clamp(1.2rem, 1.7vw, 1.9rem);
    line-height: 1.45;
    white-space: pre-line;
  }

  .debate-detail-card {
    /* 詳細結果カード: 入力カードと同じ境界線の見え方にそろえる */
    border: 1px solid rgba(0, 0, 0, 0.125);
    border-radius: 0.375rem;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
  }

  /* 詳細画面: 議題カードを隠し、フェーズカードだけを表示する */
  /* 直下の1枚目だけを隠し、フェーズ4内で複製されたカードは隠さない */
  #debatePhaseView > .debate-detail-card:first-child {
    display: none;
  }

  .debate-detail-card .card-header {
    /* 詳細結果カードのヘッダー: 入力カードと同じ境界線トーンを使う */
    background: rgba(0, 0, 0, 0.03);
    border-bottom: 1px solid rgba(0, 0, 0, 0.125);
    font-weight: 700;
  }

  .debate-detail-card .card-body,
  .debate-detail-actions .btn {
    /* 詳細UIのフォント: カードとボタンもページの継承フォントを使う */
    font-family: inherit;
  }

  .debate-phase-panel {
    min-height: 300px;
  }

  .debate-detail-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin-top: 1.5rem;
    flex-wrap: wrap;
  }

  /* トップ画面の議論プロセス紹介: フォーム下に置くカード型セクション */
  .debate-process-section {
    margin-bottom: 2rem;
  }

  .debate-process-card {
    border: 1px solid rgba(0, 0, 0, 0.125);
    border-radius: 0.75rem;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    background: #fff;
  }

  .debate-process-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .debate-process-kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    background: rgba(31, 105, 136, 0.1);
    color: #1f6988;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }

  .debate-process-title {
    margin: 0 0 0.55rem;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .debate-process-text {
    margin: 0;
    max-width: 680px;
    color: #5f6b76;
    line-height: 1.7;
  }

  .debate-process-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .debate-process-item {
    min-width: 0;
    padding: 1.25rem;
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 1rem;
    background: linear-gradient(180deg, #fff 0%, #f8fbfc 100%);
    box-shadow: 0 10px 24px rgba(15, 50, 66, 0.06);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
  }

  .debate-process-item:hover {
    transform: translateY(-4px);
    border-color: rgba(31, 105, 136, 0.4);
    box-shadow: 0 18px 36px rgba(15, 50, 66, 0.1);
  }

  .debate-process-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .debate-process-icon {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    background: rgba(31, 105, 136, 0.12);
    color: #1f6988;
    flex: 0 0 auto;
  }

  .debate-process-icon svg {
    width: 1.45rem;
    height: 1.45rem;
  }

  .debate-process-phase {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7b8791;
  }

  .debate-process-item-title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
    color: #111;
  }

  .debate-process-item-text {
    margin: 0;
    color: #5f6b76;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  @media (max-width: 991px) {
    .debate-overview-track {
      flex-direction: column;
    }

    .debate-track-link,
    .debate-track-arrow {
      display: none;
    }

    .debate-phase-box {
      width: min(100%, 320px);
      min-height: 240px;
    }

    .debate-process-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 575px) {
    .debate-process-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
`) %>

<!-- ヘッダー -->
<header class="bg-dark text-white py-4 mb-4 shadow">
  <div class="container">
    <h1 class="mb-0 fw-bold">
      <span class="text-info">Rethink</span> - AI Debate
    </h1>
    <p class="mb-0 text-secondary small">複数のアイデアをAIが4フェーズで議論し、深く考察します</p>
  </div>
</header>

<div class="pb-5">

  <!-- 入力フォームカード -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">

      <!-- 議題入力 -->
      <div class="mb-4">
        <label for="topic" class="form-label fw-semibold">議題・前提条件</label>
        <textarea
          id="topic"
          class="form-control"
          rows="3"
          placeholder="例: 新しいプロダクトのUI設計において、どちらのアプローチが優れているか"
        >大学の授業にはAIを標準的な学習ツールとして導入すべきである。</textarea><!-- デモ用プリセット: デモ終了時にこの議題文を削除する -->
      </div>

      <!-- エージェントカード群 -->
      <div id="agentsContainer" class="row mb-3">
        <!-- アイデアA（初期・削除不可） -->
        <div class="col-md-6 mb-4 agent-col" data-index="0">
          <div class="border rounded p-3 agent-card" data-agent-index="0">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-primary mb-0">アイデアA</h6>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">主張（core_claim）</label>
              <textarea class="form-control border-primary agent-claim" rows="2" placeholder="例: シンプルで直感的なデザインを優先する">大学は通常の授業にAIツールを導入すべきであり、それによって学習効率が上がり、社会で必要となる実践的な活用力も身につく。</textarea><!-- デモ用プリセット: エージェントAの主張 -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">根拠（rationale）</label>
              <textarea class="form-control border-primary agent-rationale" rows="2" placeholder="例: ユーザー調査でシンプルなUIの満足度が高く、離脱率が低い実績がある">すでに学生は授業外でAIを使っている。正式に授業へ組み込めば、教員が検証方法や引用ルール、責任ある使い方まで指導できる。</textarea><!-- デモ用プリセット: エージェントAの根拠 -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">前提条件（preconditions）</label>
              <textarea class="form-control border-primary agent-preconditions" rows="2" placeholder="例: ターゲットユーザーは技術に詳しくない一般層である">教員がAI利用ルールを明確に示し、出典確認を必須にし、単なる出力ではなく思考過程を評価する課題設計を行うことが前提である。</textarea><!-- デモ用プリセット: エージェントAの前提条件 -->
            </div>
            <div class="mb-0">
              <label class="form-label small fw-semibold">立場を支える具体的な事実・経験（任意）</label>
              <textarea class="form-control border-primary agent-experience" rows="2" placeholder="例: 実際に使ったユーザーからシンプルなUIの方が迷わないという声を聞いた">初年次ゼミでAI支援の文章作成を試験導入した経験があり、学生の推敲の質が上がる場面を観察した。</textarea><!-- デモ用プリセット: エージェントAの具体例・経験 -->
            </div>
          </div>
        </div>

        <!-- アイデアB（初期・削除不可） -->
        <div class="col-md-6 mb-4 agent-col" data-index="1">
          <div class="border rounded p-3 agent-card" data-agent-index="1">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-danger mb-0">アイデアB</h6>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">主張（core_claim）</label>
              <textarea class="form-control border-danger agent-claim" rows="2" placeholder="例: 機能を豊富に揃えたパワーユーザー向けデザインを優先する">大学の授業でのAI利用は制限すべきであり、依存が進むと基礎的な思考力が弱まり、本来の学力評価も難しくなる。</textarea><!-- デモ用プリセット: エージェントBの主張 -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">根拠（rationale）</label>
              <textarea class="form-control border-danger agent-rationale" rows="2" placeholder="例: 上位20%のヘビーユーザーが売上の80%を占め、彼らは機能の多さを評価している">AIが課題の大部分を作ってしまうと、特に学習初期の学生は内容を十分理解しないまま整った答案だけを提出できてしまう。</textarea><!-- デモ用プリセット: エージェントBの根拠 -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">前提条件（preconditions）</label>
              <textarea class="form-control border-danger agent-preconditions" rows="2" placeholder="例: ユーザーの多様なニーズに応えるためには機能の幅が必要である">少なくとも基礎科目では、まず自力で読む・書く・考える力を確立してからAIを広く導入すべきである。</textarea><!-- デモ用プリセット: エージェントBの前提条件 -->
            </div>
            <div class="mb-0">
              <label class="form-label small fw-semibold">立場を支える具体的な事実・経験（任意）</label>
              <textarea class="form-control border-danger agent-experience" rows="2" placeholder="例: ヘビーユーザーが機能の多さを理由に継続利用しているという事例を観察した">AI生成の要約に頼る学生が、持ち込み不可試験や口頭試問で十分に説明できず苦戦する様子を見てきた。</textarea><!-- デモ用プリセット: エージェントBの具体例・経験 -->
            </div>
          </div>
        </div>
      </div>

      <!-- アイデア追加ボタン -->
      <div class="mb-4">
        <button id="addAgentBtn" type="button" class="btn btn-outline-secondary">
          + アイデアを追加
        </button>
        <span class="text-muted small ms-2">（3つ以上のアイデアで多角的な議論が可能です）</span>
      </div>

      <!-- フェーズ3ターン数設定 -->
      <div class="mb-4">
        <label for="maxTurns" class="form-label fw-semibold">フェーズ3の議論ターン数（サブ議題あたり）</label>
        <div class="d-flex align-items-center gap-3">
          <input
            type="number"
            id="maxTurns"
            class="form-control"
            style="width: 100px;"
            value="2"
            min="1"
            max="2"
          >
          <span class="text-muted small">ターン（1〜2、デフォルト2で攻撃モードα→βを1サイクル）</span>
        </div>
      </div>

      <!-- 議論開始ボタン -->
      <div class="d-grid d-md-flex">
        <button id="startBtn" class="btn btn-dark btn-lg px-5">
          議論開始
        </button>
      </div>

    </div>
  </div>

  <!-- 結果表示エリア（初期非表示） -->
  <!-- トップ画面の空き領域に、議論プロセスをカード型UIで案内する -->
  <section class="debate-process-section">
    <div class="debate-process-card">
      <div class="card-body p-4 p-lg-5">
        <div class="debate-process-header">
          <div>
            <span class="debate-process-kicker">How it works</span>
            <h2 class="debate-process-title">議論プロセス</h2>
            <p class="debate-process-text">4つのフェーズを通して、AIが主張を整理し、反論を深め、最終的な結論まで導きます。</p>
          </div>
        </div>

        <div class="debate-process-grid">
          <article class="debate-process-item">
            <div class="debate-process-top">
              <span class="debate-process-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M5 7.5A2.5 2.5 0 0 1 7.5 5h9A2.5 2.5 0 0 1 19 7.5v5A2.5 2.5 0 0 1 16.5 15H11l-3.8 3v-3H7.5A2.5 2.5 0 0 1 5 12.5v-5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M8.5 9.5h7M8.5 12h4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
              <span class="debate-process-phase">Phase 1</span>
            </div>
            <h3 class="debate-process-item-title">意見表明</h3>
            <p class="debate-process-item-text">初期主張を整理し、議論の出発点を作る。</p>
          </article>

          <article class="debate-process-item">
            <div class="debate-process-top">
              <span class="debate-process-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="10.5" cy="10.5" r="4.5" stroke="currentColor" stroke-width="1.8"/>
                  <path d="m14 14 4.5 4.5M8.5 10.5h4M10.5 8.5v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
              <span class="debate-process-phase">Phase 2</span>
            </div>
            <h3 class="debate-process-item-title">反論・情報取得</h3>
            <p class="debate-process-item-text">相手の論点を分析し、反論を構築する。</p>
          </article>

          <article class="debate-process-item">
            <div class="debate-process-top">
              <span class="debate-process-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M8 6H5.5A2.5 2.5 0 0 0 3 8.5v4A2.5 2.5 0 0 0 5.5 15H6v3l3.8-3H12.5A2.5 2.5 0 0 0 15 12.5v-1" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M16 6h2.5A2.5 2.5 0 0 1 21 8.5v4A2.5 2.5 0 0 1 18.5 15H18v3l-3.8-3H11.5A2.5 2.5 0 0 1 9 12.5v-4A2.5 2.5 0 0 1 11.5 6H14" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="debate-process-phase">Phase 3</span>
            </div>
            <h3 class="debate-process-item-title">サブ議題議論</h3>
            <p class="debate-process-item-text">重要な論点を深掘りして議論する。</p>
          </article>

          <article class="debate-process-item">
            <div class="debate-process-top">
              <span class="debate-process-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M12 4v4M12 16v4M6.5 7.5 9 10M15 14l2.5 2.5M4 12h4M16 12h4M6.5 16.5 9 14M15 10l2.5-2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </span>
              <span class="debate-process-phase">Phase 4</span>
            </div>
            <h3 class="debate-process-item-title">統合・結論</h3>
            <p class="debate-process-item-text">議論をまとめて最終的な結論を導く。</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <div id="resultArea" class="d-none">

    <!-- フェーズ1: 意見表明 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ1: 意見表明</h2>
      <div class="accordion" id="phase1Accordion">
        <div id="phase1Content"></div>
      </div>
    </div>

    <!-- フェーズ2: 情報取得・反論・サブ議題抽出 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ2: 情報取得・反論・サブ議題抽出</h2>
      <div class="accordion" id="phase2Accordion">
        <div id="phase2Content"></div>
      </div>
    </div>

    <!-- フェーズ3: サブ議題別議論 -->
    <div class="mb-4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ3: サブ議題別議論</h2>
      <div class="accordion" id="phase3Accordion">
        <div id="phase3Content"></div>
      </div>
    </div>

    <!-- フェーズ4: 統合表明とまとめ -->
    <div class="mb-4">
      <!-- フェーズ4の見出しと結果本体を同じカード内にまとめて表示する -->
      <div class="card debate-detail-card">
        <div class="card-header">フェーズ4: 統合表明とまとめ</div>
        <div class="card-body">
          <div id="phase4Content"></div>
        </div>
      </div>

      <!-- 最終まとめ -->
      <div class="card border-success shadow-sm mt-4">
        <div class="card-header bg-success text-white fw-semibold">
          最終総括レポート
        </div>
        <div class="card-body">
          <p id="summaryContent" class="mb-0" style="white-space: pre-wrap;"></p>
        </div>
      </div>

    </div>

  </div>

</div>

<% block('script').append('<script src="/js/main.js"></script>') %>
<% block('script').append(`
<script>
  // 表示順の調整: 議論開始後に最初に見えるセクションを Phase 4 にする
  document.addEventListener('DOMContentLoaded', () => {
    const resultArea = document.getElementById('resultArea');
    const phase4Section = document.getElementById('phase4Content')?.closest('.mb-4');

    if (!resultArea || !phase4Section) return;

    resultArea.prepend(phase4Section);
  });
</script>
`) %>

<% block('script').append(`
<script>
  // debate2 の詳細ナビゲーション:
  // - 「詳細を確認」でクリック可能な目次画面を開く
  // - 各フェーズをクリックすると、そのフェーズ専用画面を開く
  // - 前へ / 目次へ / 次へ ボタンでフェーズ間と目次画面を移動する
  document.addEventListener('DOMContentLoaded', () => {
    const resultArea = document.getElementById('resultArea');
    const topicInput = document.getElementById('topic');
    const phase1Section = document.getElementById('phase1Content')?.closest('.mb-4');
    const phase2Section = document.getElementById('phase2Content')?.closest('.mb-4');
    const phase3Section = document.getElementById('phase3Content')?.closest('.mb-4');
    const phase4Section = document.getElementById('phase4Content')?.closest('.mb-4');

    if (!resultArea || !phase4Section) return;
    if (document.getElementById('debateDetailRoot')) return;

    const phases = [
      { title: 'フェーズ1', lines: '意見表明', source: phase1Section },
      { title: 'フェーズ2', lines: '情報取得\\n反論\\nサブ議題', source: phase2Section },
      { title: 'フェーズ3', lines: 'サブ議題別\\n議論', source: phase3Section },
      { title: 'フェーズ4', lines: '統合表明と\\nまとめ', source: phase4Section },
    ];

    const detailRoot = document.createElement('div');
    detailRoot.id = 'debateDetailRoot';
    detailRoot.className = 'debate-detail-root d-none';
    detailRoot.innerHTML = \`
      <!-- 目次画面も詳細カード上に載せて、フェーズ画面と同じ見た目にそろえる -->
      <div id="debateOverviewView" class="card debate-detail-card">
        <div class="card-body">
        <h2 class="debate-overview-title">AIたちはこのように議論しています</h2>
        <div id="debateOverviewTrack" class="debate-overview-track"></div>
        </div>
      </div>
      <div id="debatePhaseView" class="d-none">
        <div class="card debate-detail-card mb-4">
          <div class="card-header">議題</div>
          <div class="card-body">
            <p id="debateTopicText" class="mb-0" style="white-space: pre-wrap;"></p>
          </div>
        </div>
        <div class="card debate-detail-card">
          <div id="debatePhaseCardTitle" class="card-header"></div>
          <div id="debatePhaseCardBody" class="card-body debate-phase-panel"></div>
        </div>
        <div class="debate-detail-actions">
          <button id="phasePrevBtn" type="button" class="btn btn-outline-dark">前へ</button>
          <button id="phaseIndexBtn" type="button" class="btn btn-dark">目次へ</button>
          <button id="phaseNextBtn" type="button" class="btn btn-outline-dark">次へ</button>
        </div>
      </div>
    \`;
    resultArea.appendChild(detailRoot);

    const overviewView = detailRoot.querySelector('#debateOverviewView');
    const phaseView = detailRoot.querySelector('#debatePhaseView');
    const overviewTrack = detailRoot.querySelector('#debateOverviewTrack');
    const topicText = detailRoot.querySelector('#debateTopicText');
    const phaseCardTitle = detailRoot.querySelector('#debatePhaseCardTitle');
    const phaseCardBody = detailRoot.querySelector('#debatePhaseCardBody');
    const prevBtn = detailRoot.querySelector('#phasePrevBtn');
    const nextBtn = detailRoot.querySelector('#phaseNextBtn');
    const indexBtn = detailRoot.querySelector('#phaseIndexBtn');

    let currentPhaseIndex = 0;

    const hideSourceSections = () => {
      phases.forEach((phase) => {
        if (phase.source) phase.source.classList.add('d-none');
      });
    };

    const showPhase4SummaryOnly = () => {
      detailRoot.classList.add('d-none');
      phase4Section.classList.remove('d-none');
      [phase1Section, phase2Section, phase3Section].forEach((section) => {
        if (section) section.classList.add('d-none');
      });
    };

    const ensureDetailsButton = () => {
      let showDetailsBtn = document.getElementById('showDetailsBtn');

      if (showDetailsBtn) {
        const replacement = showDetailsBtn.cloneNode(true);
        replacement.textContent = '詳細を確認';
        showDetailsBtn.replaceWith(replacement);
        showDetailsBtn = replacement;
      } else {
        const buttonWrap = document.createElement('div');
        buttonWrap.className = 'mt-4';
        showDetailsBtn = document.createElement('button');
        showDetailsBtn.id = 'showDetailsBtn';
        showDetailsBtn.type = 'button';
        showDetailsBtn.className = 'btn btn-outline-dark';
        showDetailsBtn.textContent = '詳細を確認';
        buttonWrap.appendChild(showDetailsBtn);
        phase4Section.appendChild(buttonWrap);
      }

      showDetailsBtn.addEventListener('click', () => {
        renderOverview();
      });
    };

    const buildOverview = () => {
      overviewTrack.innerHTML = '';

      phases.forEach((phase, index) => {
        if (index > 0 && index < phases.length - 1) {
          const connector = document.createElement('div');
          connector.className = 'debate-track-link';
          overviewTrack.appendChild(connector);
        }

        if (index === phases.length - 1) {
          const arrow = document.createElement('div');
          arrow.className = 'debate-track-arrow';
          overviewTrack.appendChild(arrow);
        }

        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'debate-phase-box';
        button.dataset.phaseIndex = String(index);
        button.innerHTML = \`
          <div class="debate-phase-box-title">\${phase.title}</div>
          <div class="debate-phase-box-lines">\${phase.lines}</div>
        \`;

        button.addEventListener('click', () => {
          openPhase(index);
        });

        overviewTrack.appendChild(button);
      });
    };

    const clonePhaseBody = (phaseIndex) => {
      const source = phases[phaseIndex]?.source;
      if (!source) return '<p class="mb-0">表示できる内容がありません。</p>';

      const clone = source.cloneNode(true);
      clone.classList.remove('d-none');
      clone.querySelectorAll('#showDetailsBtn').forEach((node) => node.remove());
      return clone.innerHTML;
    };

    const setActiveOverviewPhase = (phaseIndex) => {
      overviewTrack.querySelectorAll('.debate-phase-box').forEach((box, index) => {
        box.classList.toggle('is-active', index === phaseIndex);
      });
    };

    const renderOverview = () => {
      /* 目次画面は一旦使わず、先頭フェーズの詳細を直接表示する */
      openPhase(0);
    };

    const openPhase = (phaseIndex) => {
      currentPhaseIndex = phaseIndex;
      hideSourceSections();
      phase4Section.classList.add('d-none');
      detailRoot.classList.remove('d-none');
      overviewView.classList.add('d-none');
      phaseView.classList.remove('d-none');

      topicText.textContent = topicInput?.value?.trim() || '議題が未入力です。';
      phaseCardTitle.textContent = phases[phaseIndex].title;
      phaseCardBody.innerHTML = clonePhaseBody(phaseIndex);
      /* 目次画面を使わない間は「目次へ」ボタンを非表示にする */
      indexBtn.classList.add('d-none');
      prevBtn.classList.toggle('d-none', phaseIndex === 0);
      nextBtn.classList.toggle('d-none', phaseIndex === phases.length - 1);
      setActiveOverviewPhase(phaseIndex);
    };

    prevBtn.addEventListener('click', () => {
      if (currentPhaseIndex > 0) openPhase(currentPhaseIndex - 1);
    });

    nextBtn.addEventListener('click', () => {
      if (currentPhaseIndex < phases.length - 1) openPhase(currentPhaseIndex + 1);
    });

    indexBtn.addEventListener('click', () => {
      renderOverview();
    });

    buildOverview();
    hideSourceSections();
    showPhase4SummaryOnly();
    ensureDetailsButton();
  });
</script>
`) %>

<% block('script').append(`
<script>
  // 詳細フェーズの制御:
  // 1. Phase 1-3 を初期状態で隠す
  // 2. Phase 4 の下に「詳細を確認」ボタンを追加する
  // 3. ボタン押下で Phase 1-3 を表示する
  document.addEventListener('DOMContentLoaded', () => {
    const phase4Section = document.getElementById('phase4Content')?.closest('.mb-4');
    const phase1Section = document.getElementById('phase1Content')?.closest('.mb-4');
    const phase2Section = document.getElementById('phase2Content')?.closest('.mb-4');
    const phase3Section = document.getElementById('phase3Content')?.closest('.mb-4');

    if (!phase4Section) return;

    [phase1Section, phase2Section, phase3Section].forEach((section) => {
      if (section) section.classList.add('d-none');
    });

    if (document.getElementById('showDetailsBtn')) return;

    const buttonWrap = document.createElement('div');
    buttonWrap.className = 'mt-4';

    const showDetailsBtn = document.createElement('button');
    showDetailsBtn.id = 'showDetailsBtn';
    showDetailsBtn.type = 'button';
    showDetailsBtn.className = 'btn btn-outline-dark';
    showDetailsBtn.textContent = '詳細を確認';

    showDetailsBtn.addEventListener('click', () => {
      [phase1Section, phase2Section, phase3Section].forEach((section) => {
        if (section) section.classList.remove('d-none');
      });
      buttonWrap.classList.add('d-none');
    });

    buttonWrap.appendChild(showDetailsBtn);
    phase4Section.appendChild(buttonWrap);
  });
</script>
`) %>
