<% layout('layout/boilerplates') %>
<% block('style').append('<link href="/css/debate.css" rel="stylesheet">') %>
<% block('style').append(`
<style>
  .debate-detail-actions {
    display: flex;
    gap: 0.75rem;
    justify-content: center;
    margin: 1rem 0 1.5rem;
    flex-wrap: wrap;
  }

  .debate-index-section {
    margin-bottom: 2rem;
  }

  .debate-index-shell {
    border: 1px solid rgba(0, 0, 0, 0.125);
    border-radius: 0.75rem;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    background: #fff;
  }

  .debate-index-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .debate-index-kicker {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.8rem;
    border-radius: 999px;
    background: rgba(31, 105, 136, 0.1);
    color: #1f6988;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.8rem;
  }

  .debate-index-title {
    margin: 0 0 0.55rem;
    font-size: clamp(1.6rem, 2.8vw, 2.2rem);
    font-weight: 700;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .debate-index-text {
    margin: 0;
    max-width: 680px;
    color: #5f6b76;
    line-height: 1.7;
  }

  .debate-index-grid {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 1rem;
  }

  .debate-index-card {
    min-width: 0;
    width: 100%;
    padding: 1.25rem;
    border: 1px solid rgba(17, 17, 17, 0.12);
    border-radius: 1rem;
    background: linear-gradient(180deg, #fff 0%, #f8fbfc 100%);
    box-shadow: 0 10px 24px rgba(15, 50, 66, 0.06);
    transition: transform 0.18s ease, box-shadow 0.18s ease, border-color 0.18s ease;
    cursor: pointer;
  }

  .debate-index-card:hover,
  .debate-index-card:focus-visible {
    transform: translateY(-4px);
    border-color: rgba(31, 105, 136, 0.4);
    box-shadow: 0 18px 36px rgba(15, 50, 66, 0.1);
    outline: none;
  }

  .debate-index-card.is-active {
    border-color: rgba(31, 105, 136, 0.55);
    box-shadow: 0 18px 36px rgba(15, 50, 66, 0.14);
  }

  .debate-index-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .debate-index-icon {
    width: 3rem;
    height: 3rem;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 0.9rem;
    background: rgba(31, 105, 136, 0.12);
    color: #1f6988;
    flex: 0 0 auto;
  }

  .debate-index-icon svg {
    width: 1.45rem;
    height: 1.45rem;
  }

  .debate-index-phase {
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #7b8791;
  }

  .debate-index-card-title {
    margin: 0 0 0.5rem;
    font-size: 1.05rem;
    font-weight: 700;
    line-height: 1.4;
    color: #111;
  }

  .debate-index-card-text {
    margin: 0;
    color: #5f6b76;
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .debate-phase-section {
    /* コメント: 各フェーズ結果全体を目次と同系統のカードUIで囲む */
    padding: 1.5rem;
    border: 1px solid rgba(0, 0, 0, 0.125);
    border-radius: 0.75rem;
    box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
    background: #fff;
    scroll-margin-top: 1.5rem;
  }

  .debate-phase-section > h2 {
    /* コメント: カード内見出しの余白を整える */
    margin-bottom: 1rem !important;
  }

  .debate-phase-section .accordion,
  .debate-phase-section #phase4Content {
    /* コメント: 見出し直下の結果本体との間隔を統一する */
    margin-top: 0.5rem;
  }

  .debate-phase-description {
    margin: -0.35rem 0 1rem;
    color: #5f6b76;
    line-height: 1.7;
  }

  .debate-step-guide {
    margin-bottom: 1rem;
    padding: 1rem 1.25rem;
    border: 1px solid rgba(17, 17, 17, 0.1);
    border-radius: 0.75rem;
    background: #f8fbfc;
  }

  .debate-step-guide-title {
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
    font-weight: 700;
    color: #1f6988;
  }

  .debate-step-guide-list {
    margin: 0;
    padding-left: 1.2rem;
    color: #5f6b76;
  }

  .debate-step-guide-list li + li {
    margin-top: 0.45rem;
  }

  .debate-mindmap-section .card + .card {
    margin-top: 1rem;
  }

  @media (max-width: 1199px) {
    .debate-index-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  @media (max-width: 991px) {
    .debate-index-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 575px) {
    .debate-index-grid {
      grid-template-columns: minmax(0, 1fr);
    }
  }
</style>
`) %>

<header class="bg-dark text-white py-4 mb-4 shadow">
  <div class="container">
    <h1 class="mb-0 fw-bold">
      <span class="text-info">Rethink</span> - AI Debate
    </h1>
    <p class="mb-0 text-secondary small">複数の AI エージェントが議論し、考えを深めます。</p>
  </div>
</header>

<div class="pb-5">
  <!-- コメント: 議題と各エージェントの立場を入力するフォーム領域 -->
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="mb-4">
        <label for="topic" class="form-label fw-semibold">議題・前提条件</label>
        <textarea
          id="topic"
          class="form-control"
          rows="3"
          placeholder="例: 新しいプロダクトの UI 設計において、どちらのアプローチが優れているか"
        ></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
      </div>

      <!-- コメント: エージェントごとの主張・理由・前提条件を入力するカード群 -->
      <div id="agentsContainer" class="row mb-3">
        <div class="col-md-6 mb-4 agent-col" data-index="0">
          <div class="border rounded p-3 agent-card" data-agent-index="0">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-primary mb-0">エージェントA</h6>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">主張</label>
              <textarea class="form-control border-primary agent-claim" rows="2" placeholder="例: シンプルで運用しやすいデザインを採用する"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">理由</label>
              <textarea class="form-control border-primary agent-rationale" rows="2" placeholder="例: ユーザー調査ではシンプルな UI の定着率が高く、学習コストも低い"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">前提条件</label>
              <textarea class="form-control border-primary agent-preconditions" rows="2" placeholder="例: ターゲットユーザーは説明不要で直感的に使えることを重視する"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
            <div class="mb-0">
              <label class="form-label small fw-semibold">立場を支える経験・知識</label>
              <textarea class="form-control border-primary agent-experience" rows="2" placeholder="例: 過去に担当したサービスで、複雑な UI よりもシンプルな設計が成果につながった"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
          </div>
        </div>

        <div class="col-md-6 mb-4 agent-col" data-index="1">
          <div class="border rounded p-3 agent-card" data-agent-index="1">
            <div class="d-flex justify-content-between align-items-center mb-3">
              <h6 class="fw-bold text-danger mb-0">エージェントB</h6>
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">主張</label>
              <textarea class="form-control border-danger agent-claim" rows="2" placeholder="例: 情報量を増やしてパワーユーザー向けの設計を採用する"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">理由</label>
              <textarea class="form-control border-danger agent-rationale" rows="2" placeholder="例: 上級ユーザーの 80% が一覧性と操作効率を重視している"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
            <div class="mb-2">
              <label class="form-label small fw-semibold">前提条件</label>
              <textarea class="form-control border-danger agent-preconditions" rows="2" placeholder="例: 上級ユーザーの継続利用が成功の鍵になる"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
            <div class="mb-0">
              <label class="form-label small fw-semibold">立場を支える経験・知識</label>
              <textarea class="form-control border-danger agent-experience" rows="2" placeholder="例: ヘビーユーザー向け機能の強化で成果が出た事例を参考にしている"></textarea><!-- コメント: デモ終了で初期入力を空に戻す -->
            </div>
          </div>
        </div>
      </div>

      <!-- コメント: エージェント追加は main.js 側の addAgentCard が担当する -->
      <div class="mb-4">
        <button id="addAgentBtn" type="button" class="btn btn-outline-secondary">
          + エージェントを追加
        </button>
        <span class="text-muted small ms-2">最大 6 人まで追加できます。</span>
      </div>

      <!-- コメント: フェーズ3の最大ターン数だけを個別に調整できる入力 -->
      <div class="mb-4">
        <label for="maxTurns" class="form-label fw-semibold">フェーズ3の議論ターン数</label>
        <div class="d-flex align-items-center gap-3">
          <input
            type="number"
            id="maxTurns"
            class="form-control"
            style="width: 100px;"
            value="2"
            min="1"
            max="2"
          >
          <span class="text-muted small">ターン数は 1〜2 の範囲で指定できます。</span>
        </div>
      </div>

      <!-- コメント: main.js の startDebate 起点となる実行ボタン -->
      <div class="d-grid d-md-flex">
        <button id="startBtn" class="btn btn-dark btn-lg px-5">
          議論開始
        </button>
      </div>
    </div>
  </div>

  <!-- コメント: overview 表示時に最終総括レポートを差し込む基準位置 -->
  <div id="summaryOverviewMount"></div>

  <!-- コメント: main.js が描画する最終総括レポート本体。overview とフェーズ5で移設して使い回す -->
  <section id="summaryReportSection" class="d-none mb-4">
    <div class="card border-success shadow-sm">
      <div class="card-header bg-success text-white fw-semibold">
        最終総括レポート
      </div>
      <div class="card-body">
        <p id="summaryContent" class="mb-0" style="white-space: pre-wrap;"></p>
      </div>
    </div>
  </section>

  <!-- コメント: debate.ejs と同じ id を維持したマインドマップ表示領域。overview では summary の直下に表示する -->
  <section id="mindmapOverviewSection" class="debate-mindmap-section d-none mb-4">
    <!-- コメント: 議論フェーズ全体を俯瞰するマインドマップ -->
    <div class="card border-success shadow-sm">
      <div class="card-header bg-success text-white fw-semibold d-flex justify-content-between align-items-center">
        <span>マインドマップ1（議論フェーズ）</span>
        <button id="downloadMindmapBtn" class="btn btn-sm btn-light d-none" type="button">
          画像を保存（PNG）
        </button>
      </div>
      <div class="card-body pb-2">
        <div id="mindmapContent" style="width:100%;height:75vh;min-height:400px;overflow:auto;border:1px solid #dee2e6;border-radius:0.375rem;"></div>
        <p class="text-muted small mt-2 mb-0 text-center">
          Ctrl＋スクロール: ズーム ／ スクロールバー: 移動
        </p>
      </div>
    </div>

    <!-- コメント: 統合フェーズの整理結果を別マインドマップとして表示 -->
    <div class="card border-success shadow-sm">
      <div class="card-header bg-success text-white fw-semibold d-flex justify-content-between align-items-center">
        <span>マインドマップ2（統合フェーズ）</span>
        <button id="downloadMindmap2Btn" class="btn btn-sm btn-light d-none" type="button">
          画像を保存（PNG）
        </button>
      </div>
      <div class="card-body pb-2">
        <div id="mindmapContent2" style="width:100%;height:75vh;min-height:400px;overflow:auto;border:1px solid #dee2e6;border-radius:0.375rem;"></div>
        <p class="text-muted small mt-2 mb-0 text-center">
          Ctrl＋スクロール: ズーム ／ スクロールバー: 移動
        </p>
      </div>
    </div>
  </section>

  <!-- コメント: 結果全体の入口となるカード型目次。overview 時のみ表示する -->
  <section id="debateIndexSection" class="debate-index-section d-none">
    <div class="debate-index-shell">
      <div class="card-body p-4 p-lg-5">
        <div class="debate-index-header">
          <div>
            <span class="debate-index-kicker">Debate Index</span>
            <h2 class="debate-index-title">目次</h2>
            <p class="debate-index-text">見たいフェーズのカードを選ぶと、そのフェーズの元セクションだけを表示します。</p>
          </div>
        </div>

        <div class="debate-index-grid">
          <article class="debate-index-card" data-phase-index="0" role="button" tabindex="0" aria-label="フェーズ1を開く">
            <div class="debate-index-top">
              <span class="debate-index-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M5 7.5A2.5 2.5 0 0 1 7.5 5h9A2.5 2.5 0 0 1 19 7.5v5A2.5 2.5 0 0 1 16.5 15H11l-3.8 3v-3H7.5A2.5 2.5 0 0 1 5 12.5v-5Z" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M8.5 9.5h7M8.5 12h4.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
              <span class="debate-index-phase">Phase 1</span>
            </div>
            <h3 class="debate-index-card-title">意見表明</h3>
            <p class="debate-index-card-text">初期主張と前提を整理し、議論の出発点を確認します。</p>
          </article>

          <article class="debate-index-card" data-phase-index="1" role="button" tabindex="0" aria-label="フェーズ2を開く">
            <div class="debate-index-top">
              <span class="debate-index-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <circle cx="10.5" cy="10.5" r="4.5" stroke="currentColor" stroke-width="1.8"/>
                  <path d="m14 14 4.5 4.5M8.5 10.5h4M10.5 8.5v4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                </svg>
              </span>
              <span class="debate-index-phase">Phase 2</span>
            </div>
            <h3 class="debate-index-card-title">情報取得・反論・サブ議題抽出</h3>
            <p class="debate-index-card-text">相手の論点を分析し、反論材料と深掘り対象の論点を整理します。</p>
          </article>

          <article class="debate-index-card" data-phase-index="2" role="button" tabindex="0" aria-label="フェーズ3を開く">
            <div class="debate-index-top">
              <span class="debate-index-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M8 6H5.5A2.5 2.5 0 0 0 3 8.5v4A2.5 2.5 0 0 0 5.5 15H6v3l3.8-3H12.5A2.5 2.5 0 0 0 15 12.5v-1" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                  <path d="M16 6h2.5A2.5 2.5 0 0 1 21 8.5v4A2.5 2.5 0 0 1 18.5 15H18v3l-3.8-3H11.5A2.5 2.5 0 0 1 9 12.5v-4A2.5 2.5 0 0 1 11.5 6H14" stroke="currentColor" stroke-width="1.8" stroke-linejoin="round"/>
                </svg>
              </span>
              <span class="debate-index-phase">Phase 3</span>
            </div>
            <h3 class="debate-index-card-title">サブ議題議論</h3>
            <p class="debate-index-card-text">主要論点を分解し、論点ごとの議論を深掘りします。</p>
          </article>

          <article class="debate-index-card" data-phase-index="3" role="button" tabindex="0" aria-label="フェーズ4を開く">
            <div class="debate-index-top">
              <span class="debate-index-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M6 6h12v4H6zM8 10v3.5M16 10v3.5M8 13.5h8M12 13.5V18" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                  <circle cx="12" cy="18.5" r="1.5" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </span>
              <span class="debate-index-phase">Phase 4</span>
            </div>
            <h3 class="debate-index-card-title">前提検証</h3>
            <p class="debate-index-card-text">反証成立の有無を確認します。</p>
          </article>

          <article class="debate-index-card" data-phase-index="4" role="button" tabindex="0" aria-label="フェーズ5を開く">
            <div class="debate-index-top">
              <span class="debate-index-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none">
                  <path d="M12 4v4M12 16v4M6.5 7.5 9 10M15 14l2.5 2.5M4 12h4M16 12h4M6.5 16.5 9 14M15 10l2.5-2.5" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"/>
                  <circle cx="12" cy="12" r="3.5" stroke="currentColor" stroke-width="1.8"/>
                </svg>
              </span>
              <span class="debate-index-phase">Phase 5</span>
            </div>
            <h3 class="debate-index-card-title">統合・結論</h3>
            <p class="debate-index-card-text">最終ラウンドと総括に向けて、結論と統合視点を確認します。</p>
          </article>
        </div>
      </div>
    </div>
  </section>

  <!-- コメント: フェーズ詳細画面。overview から遷移したときは 1 セクションずつ表示する -->
  <div id="resultArea" class="d-none">
    <!-- コメント: フェーズ1の描画先。main.js の renderPhase1 が中身を構築する -->
    <div class="mb-4 debate-phase-section" data-phase-index="0">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ1: 意見表明</h2>
      <p class="debate-phase-description">初期主張と前提を整理し、議論の出発点を確認します。</p>
      <div class="accordion" id="phase1Accordion">
        <div id="phase1Content"></div>
      </div>
    </div>

    <!-- コメント: フェーズ2の各ステップをひとつの accordion にまとめて表示する -->
    <div class="mb-4 debate-phase-section" data-phase-index="1">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ2: 情報取得・反論・サブ議題抽出</h2>
      <p class="debate-phase-description">相手の論点を分析し、根拠収集から反論整理、深掘り論点の抽出までを行います。</p>
      <div class="debate-step-guide">
        <!-- コメント: フェーズ2の各ステップ説明を結果画面内に表示 -->
        <div class="debate-step-guide-title">このフェーズで行うこと</div>
        <ol class="debate-step-guide-list">
          <li>Step1: 情報取得結果
            各エージェントが議論に必要な情報や根拠を集めます。
          </li>
          <li>Step2: 情報信頼性検証
            集めた情報の信頼性や偏りを中立視点で確認します。
          </li>
          <li>Step3: 全対全反論
            それぞれの立場から相手の主張に対する反論を組み立てます。
          </li>
          <li>Step4: サブ議題一覧
            ここから深掘りすべき論点を抽出して整理します。
          </li>
          <li>Step5: 要素分解
            論点を構成する主張、根拠、価値前提に分けて見直します。
          </li>
        </ol>
      </div>
      <div class="accordion" id="phase2Accordion">
        <div id="phase2Content"></div>
      </div>
    </div>

    <!-- コメント: フェーズ3はサブ議題ごとの入れ子 accordion で深掘りを見せる -->
    <div class="mb-4 debate-phase-section" data-phase-index="2">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ3: サブ議題議論</h2>
      <p class="debate-phase-description">主要論点を分解し、論点ごとの議論を深掘りします。</p>
      <div class="accordion" id="phase3Accordion">
        <div id="phase3Content"></div>
      </div>
    </div>

    <!-- コメント: debate.ejs から移植した前提検証セクション。フェーズ4カードからこのセクションを開く -->
    <div id="assumptionTrackSection" class="mb-4 debate-phase-section d-none" data-phase-index="3">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ4: 前提検証</h2>
      <p class="debate-phase-description">議論で置かれた前提を別トラックで揺さぶり、どこまで反証できるかを確認します。</p>
      <!-- コメント: 前提検証の結果が未生成のときに表示する案内 -->
      <p id="assumptionTrackEmptyState" class="text-muted mb-3 d-none">前提検証の結果はまだありません。</p>
      <div class="accordion" id="assumptionTrackAccordion">
        <div id="assumptionTrackContent"></div>
      </div>
    </div>

    <!-- コメント: main.js の phase4 描画先 id はそのまま使い、UI 上はフェーズ5として見せる -->
    <div class="mb-4 debate-phase-section" data-phase-index="4">
      <h2 class="fw-bold mb-3 border-bottom pb-2">フェーズ5: 統合表明とまとめ</h2>
      <p class="debate-phase-description">最終ラウンドと総括に向けて、結論と統合視点を確認します。</p>
      <div id="phase4Content"></div>
      <!-- コメント: overview 用の summary セクションを、フェーズ5表示時だけここへ差し替える -->
      <div id="phase5SummaryMount" class="mt-4"></div>
    </div>
  </div>
</div>

<% block('script').append('<script src="https://cdn.jsdelivr.net/npm/mermaid/dist/mermaid.min.js"></script>') %>
<% block('script').append('<script src="/js/main.js"></script>') %>
<% block('script').append(`
<script>
  document.addEventListener('DOMContentLoaded', () => {
    // コメント: overview 表示とフェーズ詳細表示を切り替えるための主要ノード群
    const resultArea = document.getElementById('resultArea');
    const summaryOverviewMount = document.getElementById('summaryOverviewMount');
    const summarySection = document.getElementById('summaryReportSection');
    const mindmapSection = document.getElementById('mindmapOverviewSection');
    const indexSection = document.getElementById('debateIndexSection');
    const phaseSections = Array.from(resultArea?.querySelectorAll('.debate-phase-section') || []);
    const indexCards = Array.from(indexSection?.querySelectorAll('.debate-index-card') || []);
    const assumptionTrackSection = phaseSections.find((section) => section.dataset.phaseIndex === '3');
    const assumptionTrackContent = document.getElementById('assumptionTrackContent');
    const assumptionTrackEmptyState = document.getElementById('assumptionTrackEmptyState');
    const phase5SummaryMount = document.getElementById('phase5SummaryMount');

    if (!resultArea || !summarySection || !summaryOverviewMount || !mindmapSection || !indexSection || !phaseSections.length) return;
    if (document.getElementById('debatePhaseNavBottom')) return;

    // コメント: フェーズ詳細画面の下端にだけ前後移動ナビを出す
    const createPhaseNav = (navId) => {
      const nav = document.createElement('div');
      nav.id = navId;
      nav.className = 'debate-detail-actions d-none';
      nav.innerHTML = [
        '<button data-action="prev" type="button" class="btn btn-outline-dark">前のフェーズへ</button>',
        '<button data-action="index" type="button" class="btn btn-dark">目次へ戻る</button>',
        '<button data-action="next" type="button" class="btn btn-outline-dark">次のフェーズへ</button>',
      ].join('');
      return nav;
    };

    const bottomNav = createPhaseNav('debatePhaseNavBottom');
    resultArea.insertAdjacentElement('beforeend', bottomNav);

    // コメント: 現在開いているフェーズ番号。前へ / 次へ の基準に使う
    let currentPhaseIndex = 0;

    // コメント: summary は overview では上部固定、詳細ではフェーズ5内へ移設して再利用する
    const placeSummaryInOverview = () => {
      if (summaryOverviewMount.nextElementSibling !== summarySection) {
        summaryOverviewMount.insertAdjacentElement('afterend', summarySection);
      }
    };

    const placeSummaryInPhase5 = () => {
      if (phase5SummaryMount && phase5SummaryMount.firstElementChild !== summarySection) {
        phase5SummaryMount.replaceChildren(summarySection);
      }
    };

    const hideAllPhaseSections = () => {
      phaseSections.forEach((section) => {
        section.classList.add('d-none');
      });
    };

    // コメント: カードの並び順と前後遷移は data-phase-index をそのまま使って固定化する
    const getPhaseIndices = () => phaseSections
      .map((section) => Number(section.dataset.phaseIndex));

    // コメント: フェーズ4の「空状態メッセージ」だけを内容の有無に応じて切り替える
    const updateAssumptionTrackState = () => {
      const hasAssumptionResults = Boolean(assumptionTrackContent && assumptionTrackContent.children.length > 0);
      if (assumptionTrackEmptyState) {
        assumptionTrackEmptyState.classList.toggle('d-none', hasAssumptionResults);
      }
    };

    // コメント: 目次カードの強調表示だけを担当し、表示 / 非表示の切り替えはしない
    const setActiveIndexCard = (phaseIndex) => {
      indexCards.forEach((card) => {
        const cardIndex = Number(card.dataset.phaseIndex);
        card.classList.toggle('is-active', cardIndex === phaseIndex);
      });
    };

    // コメント: 結果未表示時は overview 要素をまとめて閉じ、詳細セクションも全て隠す
    const syncResultSectionsVisibility = () => {
      const shouldHide = resultArea.classList.contains('d-none');
      placeSummaryInOverview();
      updateAssumptionTrackState();
      summarySection.classList.toggle('d-none', shouldHide);
      mindmapSection.classList.toggle('d-none', shouldHide);
      indexSection.classList.toggle('d-none', shouldHide);
      bottomNav.classList.toggle('d-none', true);
      hideAllPhaseSections();
      setActiveIndexCard(-1);
    };

    // コメント: 結果表示直後は summary -> mindmap -> index の順で overview を見せる
    const renderOverview = () => {
      hideAllPhaseSections();
      placeSummaryInOverview();
      updateAssumptionTrackState();
      bottomNav.classList.add('d-none');
      summarySection.classList.remove('d-none');
      mindmapSection.classList.remove('d-none');
      indexSection.classList.remove('d-none');
      setActiveIndexCard(-1);
      summarySection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    // コメント: 目次カード選択時は対象フェーズだけを表示し、必要に応じて summary の配置先も切り替える
    const openPhase = (phaseIndex) => {
      const targetSection = phaseSections[phaseIndex];
      if (!targetSection) return;

      const phaseIndices = getPhaseIndices();
      const phaseOrder = phaseIndices.indexOf(phaseIndex);

      currentPhaseIndex = phaseIndex;
      hideAllPhaseSections();
      updateAssumptionTrackState();
      indexSection.classList.add('d-none');
      mindmapSection.classList.add('d-none');
      bottomNav.classList.remove('d-none');
      targetSection.classList.remove('d-none');

      if (phaseIndex === 4) {
        placeSummaryInPhase5();
        summarySection.classList.remove('d-none');
      } else {
        placeSummaryInOverview();
        summarySection.classList.add('d-none');
      }

      bottomNav.querySelector('[data-action="prev"]').classList.toggle('d-none', phaseOrder <= 0);
      bottomNav.querySelector('[data-action="next"]').classList.toggle('d-none', phaseOrder === -1 || phaseOrder >= phaseIndices.length - 1);

      setActiveIndexCard(phaseIndex);
      targetSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    // コメント: 前へ / 次へ は phaseSections の並び順をそのまま使って移動する
    const handleNavClick = (event) => {
      const action = event.target.closest('button')?.dataset.action;
      if (!action) return;
      const phaseIndices = getPhaseIndices();
      const currentOrder = phaseIndices.indexOf(currentPhaseIndex);
      if (action === 'prev' && currentOrder > 0) openPhase(phaseIndices[currentOrder - 1]);
      if (action === 'next' && currentOrder > -1 && currentOrder < phaseIndices.length - 1) openPhase(phaseIndices[currentOrder + 1]);
      if (action === 'index') renderOverview();
    };

    bottomNav.addEventListener('click', handleNavClick);

    // コメント: 各目次カードにクリック / Enter / Space の操作を割り当てる
    indexCards.forEach((card) => {
      const phaseIndex = Number(card.dataset.phaseIndex);
      card.addEventListener('click', () => openPhase(phaseIndex));
      card.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault();
          openPhase(phaseIndex);
        }
      });
    });

    syncResultSectionsVisibility();

    // コメント: main.js が resultArea の d-none を切り替えたら overview / detail の見え方も同期する
    const observer = new MutationObserver(() => {
      if (resultArea.classList.contains('d-none')) {
        syncResultSectionsVisibility();
        return;
      }
      renderOverview();
    });

    observer.observe(resultArea, { attributes: true, attributeFilter: ['class'] });

    // コメント: 前提検証の描画結果に応じて、空状態メッセージだけを更新する
    if (assumptionTrackSection && assumptionTrackContent) {
      const assumptionObserver = new MutationObserver(() => {
        updateAssumptionTrackState();
      });

      assumptionObserver.observe(assumptionTrackSection, { attributes: true, attributeFilter: ['class'] });
      assumptionObserver.observe(assumptionTrackContent, { childList: true });
    }
  });
</script>
`) %>
