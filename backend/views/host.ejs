<% layout('layout/boilerplates') %>

<div class="container mt-5" style="max-width: 600px;">
    <div class="text-center mb-4">
        <h1 class="fw-bold">ホスト画面</h1>
        <p class="text-muted">参加者が揃ったら対話フェーズを開始してください</p>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="card-title"><i class="bi bi-info-circle me-2 text-primary"></i>このアプリについて</h5>
            <p class="card-text text-muted small">
                参加者はAIと1対1で対話を行い、テーマに対する自分の考えを整理します。
                全員の対話が完了したら、AIが各参加者の意見をもとに議論を行います。
            </p>
        </div>
    </div>

    <div class="card shadow mb-4 border-success">
        <div class="card-body p-4">
            <h5 class="card-title text-success"><i class="bi bi-people me-2"></i>参加者招待URL</h5>
            <p class="card-text text-muted small">このURLを参加者に共有してください</p>
            <input type="text" class="form-control mb-2" id="guestUrl" value="http://localhost:3000/room/<%= roomId %>" readonly>
            <button class="btn btn-success w-100" onclick="copyUrl('guestUrl')"><i class="bi bi-clipboard me-1"></i>URLをコピー</button>
        </div>
    </div>

    <div class="card shadow-sm mb-4 border-primary">
        <div class="card-body p-4">
            <h5 class="card-title text-primary"><i class="bi bi-people me-2"></i>参加状況</h5>
            <p class="card-text text-muted small">現在ロビーに参加している人数です</p>
            <h2 class="text-center fw-bold"><span id="count">0</span><span class="fs-5 text-muted"> 人が参加中</span></h2>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="card-title"><i class="bi bi-chat-square-text me-2 text-primary"></i>議題・前提条件を設定</h5>
            <p class="card-text text-muted small">議題と前提条件をまとめて入力してください</p>
            <textarea class="form-control" id="topicInput" rows="6" placeholder="例: リモートワークは原則化すべきか&#10;&#10;前提条件:&#10;・対象はデスクワーク中心の職種&#10;・技術的インフラは整っているものとする"></textarea>
        </div>
    </div>

    <div class="card shadow-sm mb-4">
        <div class="card-body p-4">
            <h5 class="card-title"><i class="bi bi-play-circle me-2 text-success"></i>対話フェーズを開始</h5>
            <p class="card-text text-muted small">ボタンを押すと全員が同時に対話フェーズに移行します</p>
            <button class="btn btn-success w-100 mt-2" id="startBtn"><i class="bi bi-play-fill me-1"></i>対話フェーズを開始する</button>
        </div>
    </div>
</div>

<script src="/socket.io/socket.io.js"></script>
<script>
    const socket = io();
    const roomId = '<%= roomId %>';

    socket.on('connect', () => {
        socket.emit('joinRoom', roomId);
    });

    socket.on('updateCount', (count, max) => {
        document.getElementById('count').textContent = count + ' / ' + max;
    });

    // dialogページに遷移する際にソケットIDとルームIDを渡す
    socket.on('redirect', (url) => {
        window.location.href = url + '?socketId=' + socket.id + '&roomId=' + '<%= roomId %>' + '&isHost=true';
    });

    document.getElementById('startBtn').addEventListener('click', () => {
        const topic = document.getElementById('topicInput').value.trim();
        if (!topic) {
            alert('議題・前提条件を入力してください');
            return;
        }
        const countText = document.getElementById('count').textContent;
        const current = parseInt(countText.split('/')[0]);
        if (current < 2) {
            alert('参加者が2人以上必要です');
            return;
        }
        socket.emit('start', roomId, topic);
    });
</script>